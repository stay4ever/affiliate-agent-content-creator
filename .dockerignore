# ============================================================
#  .dockerignore — affiliate-agent-content-creator
# ============================================================
#  Prevents secrets, generated output, and irrelevant files
#  from being sent to the Docker build context, reducing build
#  time and eliminating the risk of leaking secrets into the image.
# ============================================================

# Secrets — never bake into image
.env

# Generated output — can be large, never needed at build time
output/

# Project assets not required by the build
AffiliateAgent-Marketplace-Guide.pdf

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Git history
.git/
.gitignore

# Docs & local config
*.md
docker-compose.yml
