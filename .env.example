# ============================================================
#  affiliate-agent-content-creator — environment variables
# ============================================================
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to version control.
# ============================================================

# ----------------------------------------------------------
# LLM credentials
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ----------------------------------------------------------
# Content generation settings
# ----------------------------------------------------------
# Directory where generated Markdown articles are saved.
CONTENT_OUTPUT_DIR=./output

# Default Anthropic model to use.
# Use claude-haiku-4-5 for development/staging (fast, low-cost).
# Use claude-sonnet-4-5 for balanced production workloads.
# Use claude-opus-4-5 for highest-quality production output only.
# Options: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
ANTHROPIC_MODEL=claude-haiku-4-5

# Maximum tokens for a single generation call (global default).
ANTHROPIC_MAX_TOKENS=8192

# Per-content-type token overrides — take precedence over ANTHROPIC_MAX_TOKENS.
# Useful when different content types need different output lengths,
# or when switching to a model with a larger/smaller context window.
# Uncomment and set the types you want to override:
# ANTHROPIC_MAX_TOKENS_REVIEW=4096
# ANTHROPIC_MAX_TOKENS_COMPARISON=6144
# ANTHROPIC_MAX_TOKENS_BUYING_GUIDE=12288
# ANTHROPIC_MAX_TOKENS_HOW_TO=4096
# ANTHROPIC_MAX_TOKENS_LISTICLE=4096
# ANTHROPIC_MAX_TOKENS_ROUNDUP=8192

# ----------------------------------------------------------
# Logging / debug
# ----------------------------------------------------------
# Set to DEBUG for verbose output, INFO for normal operation.
LOG_LEVEL=INFO
